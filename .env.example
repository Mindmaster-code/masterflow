# DATABASE
# Obtenha sua connection string no Vercel Dashboard
DATABASE_URL="postgres://default:PASSWORD@HOST.postgres.vercel-storage.com:5432/verceldb?sslmode=require"

# OPENAI (para análise de perfil LinkedIn)
OPENAI_API_KEY="sk-..."

# NEXTAUTH
# Gere uma secret key com: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-key-here"
# Local: http://localhost:3000 | Produção: https://masterflow-flame.vercel.app
NEXTAUTH_URL="http://localhost:3000"

# RESEND (e-mail ao cadastrar usuário — https://resend.com)
# RESEND_API_KEY: API Keys no painel Resend
#
# EMAIL_FROM — duas opções:
#
# A) Modo teste (sem DNS no seu domínio)
#    EMAIL_FROM="MasterFlow <onboarding@resend.dev>"
#    Só pode enviar PARA o e-mail da sua conta Resend (ex.: quem logou com Google).
#    No admin, cadastre o usuário com ESSE mesmo e-mail para receber o teste.
#
# B) Produção com seu domínio (ex.: mindmaster.com.br)
#    No Resend: Domains → adicionar mindmaster.com.br → copiar os 3 registros DNS (SPF/DKIM).
#    Após "Verified", use por exemplo:
#    EMAIL_FROM="MasterFlow <noreply@mindmaster.com.br>"
#    NÃO use @mindmaster.com.br no FROM antes de verificar o domínio — a API falha e nada é enviado.
RESEND_API_KEY="re_..."
EMAIL_FROM="MasterFlow <onboarding@resend.dev>"
